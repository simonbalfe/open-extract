{
  "name": "open-extract",
  "version": "0.1.0",
  "description": "Standalone URL-to-Markdown extraction library and CLI.",
  "type": "module",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "open-extract": "src/cli.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "cli": "bun run src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "bun test && bun run typecheck"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@tavily/core": "^0.7.6",
    "cheerio": "^1.2.0",
    "domhandler": "^6.0.1",
    "impit": "^0.14.1",
    "linkedom": "^0.18.12",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/turndown": "^5.0.6",
    "typescript": "^5"
  }
}
